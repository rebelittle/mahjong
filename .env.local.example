# Copy this file to .env.local and fill in real values.
# These are PUBLIC keys — safe to ship to the browser. Auth is enforced by
# Clerk (session tokens) and Supabase Row-Level Security (which validates
# the Clerk JWT via Supabase's third-party auth integration).

# From Clerk dashboard → API keys → Publishable key (pk_test_… or pk_live_…)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# From Supabase project → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
